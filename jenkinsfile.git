#!/bin/bash

# Simulate Jenkins pipeline locally

echo "Starting Terraform pipeline..."

# Navigate to Terraform directory
cd "/Users/sainikhilaponugoti/sunny .py/terraform-ec2-project/terraform-ec2-project" || exit 1

# Terraform Init
echo "Running terraform init..."
terraform init

# Terraform Plan
echo "Running terraform plan..."
terraform plan

# Terraform Apply
echo "Running terraform apply -auto-approve..."
terraform apply -auto-approve

echo "Pipeline completed."